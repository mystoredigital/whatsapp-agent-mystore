# Server
PORT=3000
DASHBOARD_USER=admin
DASHBOARD_PASS=changeme

# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-xxxx
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=https://wa.mystoredigital.cloud
OPENROUTER_SITE_NAME=My Store WhatsApp Agent

# Google Calendar
GOOGLE_SERVICE_ACCOUNT_FILE=./credentials/google-service-account.json
GOOGLE_CALENDAR_ID=primary
TIMEZONE=America/Guayaquil

# Negocio
BUSINESS_NAME=My Store Digital
BUSINESS_DESCRIPTION=Agencia de automatización con IA. Construimos agentes de WhatsApp, integraciones con CRM y deployment en VPS.

# Anti-ban / patrón humano para auto-respuestas de IA
# Delay aleatorio antes de enviar (ms). Total = max(LLM_latency, jitter(min,max))
HUMAN_DELAY_MIN_MS=3000
HUMAN_DELAY_MAX_MS=12000
# Cooldown mínimo entre respuestas IA al mismo chat (ms)
PER_CHAT_COOLDOWN_MS=4000
# Tope global de mensajes salientes IA por minuto (ventana deslizante)
GLOBAL_MAX_PER_MIN=20
# Horas en las que NO se auto-responde (zona TIMEZONE). Si start==end, deshabilitado.
QUIET_HOURS_START=23
QUIET_HOURS_END=7
# true = primer mensaje de un contacto nuevo escala a humano en vez de auto-responder
NEW_CONTACT_REQUIRES_HUMAN=false

# GoHighLevel (app privada Marketplace)
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
GHL_SHARED_SECRET=
GHL_CONVERSATION_PROVIDER_ID=
GHL_REDIRECT_URI=https://wa.mystoredigital.cloud/oauth/callback
# Public key PEM de la app del Marketplace (multilínea — usar comillas en docker compose).
# Cuando se configura, /webhooks/ghl/* rechaza POSTs sin x-wh-signature válida.
# Sin esto, los webhooks se aceptan en modo dev (con warning).
GHL_WEBHOOK_PUBLIC_KEY=

# Flujo "odoopago" → webhook de n8n
# Cuando un mensaje de WhatsApp empieza con la palabra "odoopago", su contenido
# (texto + imagen del comprobante si la hay) se reenvía a este webhook en vez de
# pasar por la IA. n8n debe responder un JSON con { "mensaje_confirmacion": "..." }.
# Si se deja vacía, el branch se desactiva y esos mensajes siguen el flujo normal.
N8N_ODOOPAGO_WEBHOOK_URL=
# Timeout de la llamada al webhook en milisegundos (default 30000).
N8N_ODOOPAGO_TIMEOUT_MS=30000
